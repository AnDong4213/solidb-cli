{
  "name": "solidb-cli",
  "version": "1.0.0",
  "description": "A CLI for making the SolidJS development experience easier, faster, and less error prone.",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnDong4213/solidb-cli"
  },
  "scripts": {
    "build": "turbo run build",
    "release": "pnpm build && changeset publish",
    "start": "pnpm build && cd packages/create-solid && pnpm start",
    "dev": "cd packages/create-solidb && pnpm start",
    "format": "prettier --write .",
    "watch:build": "turbo watch build"
  },
  "contributors": [
    {
      "name": "Andof Zhao"
    },
    {
      "name": "Wei Xu"
    }
  ],
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "workspaces": [
    "./packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  }
}